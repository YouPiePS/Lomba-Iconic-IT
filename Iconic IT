rain, X_test, y_train, y_test = train_test_split(X, y, test_size=tester, random_state=0)\n","    # Proses menghitung metrik evaluasi\n","    test_size_rf = RandomForestClassifier(n_estimators=100, random_state=500).fit(X_train, y_train)\n","    test_size_rf_pred = test_size_rf.predict(X_test)\n","    accuracy = accuracy_score(y_test, test_size_rf_pred)\n","    accuracy_list.append(accuracy)\n","    precision = precision_score(y_test, test_size_rf_pred)\n","    precision_list.append(precision)\n","    recall = recall_score(y_test, test_size_rf_pred)\n","    recall_list.append(recall)\n","    f1 = f1_score(y_test, test_size_rf_pred)\n","    f1_list.append(f1)\n","    # Menyimpan metrik evaluasi, test_size terbaik, dan hasil prediksi dari skor terbaik\n","    if accuracy>best_accuracy :\n","        best_accuracy = accuracy\n","        best_precision = precision\n","        best_recall = recall\n","        best_f1 = f1\n","        best_test = tester\n","        best_pred = test_size_rf_pred\n","\n","print('Test Size terbaik : {}'.format(best_test))\n","print('Accuracy terbaik : {}'.format(best_accuracy))\n","print('Precision terbaik : {}'.format(best_precision))\n","print('Recall terbaik : {}'.format(best_recall))\n","print('F1 Score terbaik : {}'.format(best_f1))\n","\n","# Plot\n","fig, ax = plt.subplots(1, 2, figsize=(12, 4))\n","ax[0].plot(test_list, accuracy_list, c='blue', label='Accuracy')\n","ax[0].set_title(\"Accuracy\")\n","ax[0].legend()\n","\n","ax[1].plot(test_list, precision_list, c='red', label='Precision')\n","ax[1].set_title(\"Precision\")\n","ax[1].legend()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":478},"executionInfo":{"status":"ok","timestamp":1725076453500,"user_tz":-420,"elapsed":7995,"user":{"displayName":"Yovie Pradea Sandiana","userId":"14670851825599453506"}},"outputId":"62c2341a-6eec-44d0-823c-2da91a90555b","id":"UV6Q6oInjUGC"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout"